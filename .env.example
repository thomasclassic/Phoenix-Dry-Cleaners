# Copy this file to .env.local and fill in your Stripe credentials

# Server-side secret key used only on the backend.
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Publishable key used by the frontend Stripe JS SDK.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# The Stripe Price ID for the checkout item.
VITE_STRIPE_PRICE_ID=price_your_price_id_here

# Optional: custom server port for local development
PORT=4242
